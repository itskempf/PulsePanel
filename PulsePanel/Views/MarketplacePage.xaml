
<Page x:Class="PulsePanel.Views.MarketplacePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <TextBlock Text="Marketplace" FontSize="22" FontWeight="Bold"/>
    <DockPanel Grid.Row="1">
      <Button Content="Refresh" Command="{Binding Refresh}" DockPanel.Dock="Top"/>
      <ListView ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}">
        <ListView.View>
          <GridView>
            <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="250"/>
            <GridViewColumn Header="Type" DisplayMemberBinding="{Binding ProvisionerType}" Width="120"/>
            <GridViewColumn Header="Action" Width="140">
              <GridViewColumn.CellTemplate>
                <DataTemplate>
                  <Button Content="Install" Click="Install_Click"/>
                </DataTemplate>
              </GridViewColumn.CellTemplate>
            </GridViewColumn>
          </GridView>
        </ListView.View>
      </ListView>
    </DockPanel>
  </Grid>
</Page>
