<Window
    x:Class="Pulse_Panel.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Pulse_Panel"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <NavigationView
        x:Name="RootNavigationView"
        PaneDisplayMode="Left"
        IsBackButtonVisible="Collapsed"
        IsBackEnabled="False"
        ItemInvoked="RootNavigationView_ItemInvoked">
        <NavigationView.PaneHeader>
            <TextBlock Text="PulsePanel" Style="{StaticResource TitleTextBlockStyle}" Margin="12,0,0,0" />
        </NavigationView.PaneHeader>
        
        <NavigationView.MenuItems>
            <NavigationViewItem Content="Servers" Tag="ServersPage">
                <NavigationViewItem.Icon>
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE91D;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            
            <NavigationViewItem Content="Blueprints" Tag="BlueprintsPage">
                <NavigationViewItem.Icon>
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8A5;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <NavigationViewItem Content="Plugins" Tag="PluginsPage">
                <NavigationViewItem.Icon>
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8D2;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>

            <NavigationViewItem Content="Audit Log" Tag="AuditLogPage">
                <NavigationViewItem.Icon>
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE8F1;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <NavigationView.PaneFooter>
            <NavigationViewItem Content="Settings" Tag="SettingsPage">
                <NavigationViewItem.Icon>
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE713;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.PaneFooter>
        
        <Frame x:Name="ContentFrame" />
        
    </NavigationView>
</Window>