{
  "version": 1,
  "games": [
    {
      "id": "cs2",
      "label": "Counter-Strike 2 (Dedicated)",
      "install": { "appId": 730 },
      "start": {
        "exec": "game/bin/linuxsteamrt64/cs2",
        "args": "-dedicated -console +game_type 0 +game_mode 1 +map de_inferno -port {{port}}"
      },
      "defaultPorts": { "27015/udp": 27015, "27015/tcp": 27015 },
      "tokens": { "port": 27015, "hostname": "PulsePanel CS2" },
      "templates": []
    },
    {
      "id": "valheim",
      "label": "Valheim",
      "install": { "appId": 896660 },
      "start": {
        "exec": "valheim_server.x86_64",
        "args": "-name \"{{hostname}}\" -port {{port}} -world \"{{world}}\" -password \"{{password}}\" -public 1"
      },
      "defaultPorts": { "2456/udp": 2456, "2457/udp": 2457, "2458/udp": 2458 },
      "tokens": { "hostname": "Pulse Valheim", "world": "Dedicated", "password": "changeme", "port": 2456 },
      "templates": [
        {
          "Target": "start.sh",
          "Content": "#!/bin/bash\nexport TEMP=/tmp\n./valheim_server.x86_64 -name \"{{hostname}}\" -port {{port}} -world \"{{world}}\" -password \"{{password}}\" -public 1"
        }
      ]
    },
    {
      "id": "generic-steam",
      "label": "Generic (Steam AppID)",
      "install": { "appId": 4020 },
      "start": { "exec": "srcds_run", "args": "-game garrysmod -console -port {{port}}" },
      "defaultPorts": { "27015/udp": 27015, "27015/tcp": 27015 },
      "tokens": { "port": 27015 },
      "templates": []
    }
  ]
}
