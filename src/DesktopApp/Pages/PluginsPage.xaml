<Page
    x:Class="PulsePanel.DesktopApp.Pages.PluginsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:local="using:PulsePanel.Core.Services">

    <Grid ColumnDefinitions="2*,3*">
        <StackPanel Grid.Column="0" Margin="10">
            <Button Content="Reload Plugins" Click="ReloadPlugins_Click" Margin="0,0,0,10"/>
            <ListView x:Name="PluginListView" ItemsSource="{Binding}" SelectionChanged="PluginListView_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:Plugin">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="{Binding Version}" FontSize="12" Foreground="Gray"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>

        <ScrollViewer Grid.Column="1" Margin="10">
            <StackPanel x:Name="PluginDetailsPanel">
                <TextBlock Text="Plugin Details" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,10"/>
                <TextBlock x:Name="PluginName" FontWeight="Bold" FontSize="20"/>
                <TextBlock x:Name="PluginVersion" FontSize="14" Foreground="Gray"/>
                <TextBlock x:Name="PluginLicense" Margin="0,5,0,0"/>
                <TextBlock x:Name="PluginSha256Hash" Margin="0,5,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
