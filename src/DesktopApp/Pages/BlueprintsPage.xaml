<Page
    x:Class="PulsePanel.DesktopApp.Pages.BlueprintsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid ColumnDefinitions="2*,3*">
        <StackPanel Grid.Column="0" Margin="10">
            <TextBox x:Name="SearchBox" PlaceholderText="Search blueprints" Margin="0,0,0,10"/>
            <ListView x:Name="BlueprintListView" ItemsSource="{Binding}" SelectionChanged="BlueprintListView_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="{Binding Version}" FontSize="12" Foreground="Gray"/>
                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>

        <ScrollViewer Grid.Column="1" Margin="10">
            <StackPanel x:Name="MetadataPanel">
                <TextBlock Text="Metadata Preview" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,10"/>
                <TextBlock x:Name="BlueprintName" FontWeight="Bold" FontSize="20"/>
                <TextBlock x:Name="BlueprintVersion" FontSize="14" Foreground="Gray"/>
                <TextBlock x:Name="BlueprintDescription" TextWrapping="Wrap" Margin="0,10,0,0"/>
                <TextBlock x:Name="BlueprintAuthor" Margin="0,5,0,0"/>
                <TextBlock x:Name="BlueprintLicense" Margin="0,5,0,0"/>
                <TextBlock x:Name="BlueprintSourceUrl" Margin="0,5,0,0"/>
                <TextBlock x:Name="BlueprintSourceHash" Margin="0,5,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
