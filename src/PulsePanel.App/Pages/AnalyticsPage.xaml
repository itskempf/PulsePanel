<Page
    x:Class="PulsePanel.App.Pages.AnalyticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PulsePanel.App.Pages"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20" RowDefinitions="Auto,*">
        <TextBlock Text="Server Analytics"
                   Style="{StaticResource HeaderTextBlockStyle}" />

        <StackPanel Grid.Row="1" Spacing="20">
            <toolkit:Chart x:Name="CpuChart" Header="CPU % Over Time">
                <toolkit:LineSeries
                    ItemsSource="{x:Bind ViewModel.SelectedServerHistory}"
                    IndependentValuePath="Timestamp"
                    DependentValuePath="CpuPercent" />
            </toolkit:Chart>

            <toolkit:Chart x:Name="MemoryChart" Header="Memory MB Over Time">
                <toolkit:LineSeries
                    ItemsSource="{x:Bind ViewModel.SelectedServerHistory}"
                    IndependentValuePath="Timestamp"
                    DependentValuePath="MemoryMb" />
            </toolkit:Chart>
        </StackPanel>
    </Grid>
</Page>
