<Page
    x:Class="PulsePanel.App.Views.NodesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PulsePanel.App.ViewModels"
    xmlns:models="using:PulsePanel.App.Models">
    <Page.DataContext>
        <vm:NodesAdminViewModel />
    </Page.DataContext>

    <StackPanel Padding="12" Spacing="8">
        <TextBlock Text="Nodes" FontSize="20" FontWeight="Bold"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox PlaceholderText="Name" Text="{x:Bind ViewModel.NewNodeName, Mode=TwoWay}" Width="180"/>
            <TextBox PlaceholderText="URL" Text="{x:Bind ViewModel.NewNodeUrl, Mode=TwoWay}" Width="240"/>
            <PasswordBox x:Name="ApiKeyBox" Width="200"/>
            <Button Content="Add" Click="OnAdd"/>
        </StackPanel>
        <ListView ItemsSource="{x:Bind ViewModel.Nodes}" SelectedItem="{x:Bind ViewModel.SelectedNode, Mode=TwoWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:NodeInfo">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{x:Bind Name}" Width="180"/>
                        <TextBlock Text="{x:Bind Url}" Width="260"/>
                        <TextBlock Text="{x:Bind Status}" Width="90"/>
                        <TextBlock Text="{x:Bind LastCheckIn}" Width="180"/>
                        <Button Content="Remove" Command="{x:Bind ViewModel.RemoveCommand}" CommandParameter="{x:Bind}"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</Page>