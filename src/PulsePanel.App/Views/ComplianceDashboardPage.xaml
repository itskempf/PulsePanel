<Page
    x:Class="PulsePanel.App.Views.ComplianceDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PulsePanel.App.ViewModels"
    xmlns:models="using:PulsePanel.App.Models">
    <Page.DataContext>
        <vm:ComplianceDashboardViewModel />
    </Page.DataContext>

    <StackPanel Padding="12" Spacing="8">
        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock Text="Compliance" FontSize="20" FontWeight="Bold"/>
            <ToggleSwitch Header="Self‑Healing" IsOn="{x:Bind ViewModel.SelfHealingEnabled, Mode=TwoWay}"/>
            <Button Content="Scan All" Command="{x:Bind ViewModel.ScanAllCommand}"/>
        </StackPanel>

        <ListView ItemsSource="{x:Bind ViewModel.Reports}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ComplianceReport">
                    <StackPanel>
                        <TextBlock Text="{x:Bind BlueprintName}" FontWeight="Bold"/>
                        <TextBlock Text="{x:Bind Overall}"/>
                        <ItemsControl ItemsSource="{x:Bind Results}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ComplianceResult">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind Rule.Description}" Width="280"/>
                                        <TextBlock Text="{x:Bind Status}" Width="90"/>
                                        <TextBlock Text="{x:Bind Message}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</Page>