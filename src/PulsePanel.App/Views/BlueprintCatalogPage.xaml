<Page
    x:Class="PulsePanel.App.Views.BlueprintCatalogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PulsePanel.App.ViewModels">

    <Page.DataContext>
        <vm:BlueprintCatalogViewModel />
    </Page.DataContext>

    <StackPanel Padding="12" Spacing="8">
        <TextBlock Text="Blueprint Catalog" FontSize="20" FontWeight="Bold"/>
        <ListView ItemsSource="{x:Bind ViewModel.Blueprints}" 
                  SelectedItem="{x:Bind ViewModel.SelectedBlueprint, Mode=TwoWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Blueprint">
                    <StackPanel>
                        <TextBlock Text="{x:Bind Name}" FontWeight="Bold"/>
                        <TextBlock Text="{x:Bind Description}" FontStyle="Italic"/>
                        <TextBlock Text="{x:Bind Version}" Foreground="Gray"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Install" Command="{x:Bind ViewModel.InstallAsyncCommand}"/>
            <Button Content="Update" Command="{x:Bind ViewModel.UpdateAsyncCommand}"/>
            <Button Content="Validate" Command="{x:Bind ViewModel.ValidateAsyncCommand}"/>
        </StackPanel>

        <TextBlock Text="{x:Bind ViewModel.StatusMessage}" Foreground="Gray"/>
    </StackPanel>
</Page>