<Window
    x:Class="PulsePanel.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PulsePanel.App">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <StackPanel Background="#1E1E1E" Padding="10">
            <TextBlock Text="PulsePanel" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            <Button Content="Servers" Command="{Binding NavigateServersCommand}" Margin="0,0,0,5"/>
            <Button Content="Blueprints" Command="{Binding NavigateBlueprintsCommand}" Margin="0,0,0,5"/>
            <Button Content="Plugins" Command="{Binding NavigatePluginsCommand}" Margin="0,0,0,5"/>
            <Button Content="Audit Log" Command="{Binding NavigateAuditLogCommand}" Margin="0,0,0,5"/>
            <Button Content="Settings" Command="{Binding NavigateSettingsCommand}" Margin="0,0,0,5"/>
        </StackPanel>

        <!-- Main Content Frame -->
    <Frame x:Name="MainFrame" Grid.Column="1" />

        <!-- Detail Pane -->
        <StackPanel Grid.Column="2" Padding="10" Background="#F3F3F3">
            <TextBlock Text="Server Details" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="{Binding SelectedServer.Name}" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding SelectedServer.Status}" Margin="0,5,0,0"/>
            <TextBlock Text="{Binding SelectedServer.Path}" Margin="0,5,0,0"/>
            <TextBlock Text="{Binding SelectedServer.Game}" Margin="0,5,0,0"/>
            <TextBlock Text="Health Score:" FontWeight="Bold" Margin="0,10,0,0"/>
            <TextBlock Text="{Binding SelectedServer.HealthScore}"/>
            <TextBlock Text="Capabilities:" FontWeight="Bold" Margin="0,10,0,0"/>
            <TextBlock Text="{Binding SelectedServer.Capabilities}"/>
            <TextBlock Text="Blueprint:" FontWeight="Bold" Margin="0,10,0,0"/>
            <TextBlock Text="{Binding SelectedServer.Blueprint}"/>
            <TextBlock Text="Ports:" FontWeight="Bold" Margin="0,10,0,0"/>
            <TextBlock Text="{Binding SelectedServer.Ports}"/>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0" Spacing="10">
                <Button Content="Manage" Width="100"/>
                <Button Content="View Audit" Width="100"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
